<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- ── Top status bar ──────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Pulsing dot indicator -->
        <View
            android:id="@+id/indicatorDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_dot_active"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CCTV ACTIVE"
            android:textColor="@color/green_accent"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- ── Camera preview (hidden when Power Saver active) ─────────── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toTopOf="@id/overlayCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:scaleType="fillCenter" />

    <!-- Scan-line overlay (decorative) -->
    <View
        android:id="@+id/scanlineOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_scanlines"
        android:alpha="0.08"
        android:clickable="false"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toTopOf="@id/overlayCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Motion alert flash overlay -->
    <View
        android:id="@+id/motionFlash"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/red_alert"
        android:alpha="0"
        android:clickable="false"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toTopOf="@id/overlayCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- REC badge -->
    <LinearLayout
        android:id="@+id/recBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_rec_badge"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="14dp"
        android:layout_marginTop="14dp">

        <View
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/bg_dot_rec"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REC"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- ── Motion status chip ──────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvMotionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● MONITORING"
        android:textColor="@color/green_accent"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:background="@drawable/bg_chip"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        app:layout_constraintBottom_toTopOf="@id/overlayCard"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="14dp"
        android:layout_marginBottom="12dp" />

    <!-- ── Bottom control panel ────────────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/overlayCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="0dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Stream URL row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/bg_inset"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_wifi"
                    android:layout_marginEnd="10dp"
                    app:tint="@color/green_accent" />

                <TextView
                    android:id="@+id/tvStreamUrl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Waiting for network…"
                    android:textColor="@color/green_accent"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <ImageButton
                    android:id="@+id/btnCopyUrl"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_copy"
                    android:contentDescription="Copy URL"
                    app:tint="@color/text_dim" />
            </LinearLayout>

            <!-- Action buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="3">

                <!-- Power Saver -->
                <LinearLayout
                    android:id="@+id/btnPowerSaver"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_secondary"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_moon"
                        android:layout_marginBottom="4dp"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Power\nSaver"
                        android:gravity="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <!-- Stop -->
                <LinearLayout
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_danger"
                    android:layout_marginHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_stop"
                        android:layout_marginBottom="4dp"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stop\nService"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <!-- Settings -->
                <LinearLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_secondary"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_settings"
                        android:layout_marginBottom="4dp"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:gravity="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
